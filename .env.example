# App Settings
MAS_AUTH_PORT=8080
MAS_AUTH_DEBUG=false
MAS_AUTH_PROXY_FIX=true

# LDAP Settings
# Comma-separated list of LDAP servers
MAS_AUTH_LDAP_SERVERS=ldaps://10.1.1.1:636,ldap://10.1.1.2:389
MAS_AUTH_LDAP_TLS_VERIFY=false

# Bind Credentials
MAS_AUTH_BINDDN="cn=LDAP Bind User,cn=Users,dc=ad,dc=local"
MAS_AUTH_BINDPASSWORD=Pa55w0rd

# Search Settings
MAS_AUTH_SEARCHBASE=cn=Users,dc=ad,dc=local
MAS_AUTH_USERFILTER=(sAMAccountName={})
MAS_AUTH_GROUPFILTER=(&(objectClass=group)(member={}))

# JWT Settings
MAS_AUTH_SECRETKEY=supersecretkey
MAS_AUTH_TOKEN_LIFETIME=3600
